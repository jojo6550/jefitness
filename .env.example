# Server Configuration
PORT=5500
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# MongoDB
MONGO_URI=mongodb://localhost:27017/jefitness

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Encryption Keys (IMPORTANT: For production, use strong keys with at least 32 characters)
# These keys are used to encrypt sensitive user data (phone, DOB, medical conditions, etc.)
# If not set, sensitive fields will NOT be encrypted (not recommended for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_encryption_key_here_minimum_32_characters_required
SIGNING_KEY=your_signing_key_here_minimum_32_characters_required

# Google OAuth (Social Login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5500/api/v1/auth/google/callback

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Subscription Products (recurring)
STRIPE_PRODUCT_1_MONTH=prod_xxxxx
STRIPE_PRICE_1_MONTH=price_xxxxx
STRIPE_PRODUCT_3_MONTH=prod_xxxxx
STRIPE_PRICE_3_MONTH=price_xxxxx
STRIPE_PRODUCT_6_MONTH=prod_xxxxx
STRIPE_PRICE_6_MONTH=price_xxxxx
STRIPE_PRODUCT_12_MONTH=prod_xxxxx
STRIPE_PRICE_12_MONTH=price_xxxxx

# Stripe Program Products (one-time payment)
# Format: STRIPE_PROGRAM_PRODUCT_<SLUG>=prod_xxxxx
# Format: STRIPE_PROGRAM_PRICE_<SLUG>=price_xxxxx
STRIPE_PROGRAM_PRODUCT_WEIGHT_LOSS=prod_xxxxx
STRIPE_PROGRAM_PRICE_WEIGHT_LOSS=price_xxxxx
STRIPE_PROGRAM_PRODUCT_MUSCLE_BUILDING=prod_xxxxx
STRIPE_PROGRAM_PRICE_MUSCLE_BUILDING=price_xxxxx
STRIPE_PROGRAM_PRODUCT_ATHLETIC_PERFORMANCE=prod_xxxxx
STRIPE_PROGRAM_PRICE_ATHLETIC_PERFORMANCE=price_xxxxx

# Email Configuration
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_SENDER_EMAIL=noreply@jefitness.com

# Cleanup Configuration
CLEANUP_TIME=30
CRON_SCHEDULE=*/30 * * * *