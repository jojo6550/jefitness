{
  "name": "jojo6550.github.io",
  "version": "2.0.0",
  "description": "Production Ready (Subscription Update)",
  "main": "./src/server.js",
  "scripts": {
    "lint": "eslint --config eslint.config.mjs src/**/*.js scripts/**/*.js",
    "lint:fix": "eslint --config eslint.config.mjs src/**/*.js scripts/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"scripts/**/*.js\"",
    "dev": "nodemon",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=src/tests/unit",
    "test:integration": "jest --testPathPattern=src/tests/integration",
    "test:frontend": "jest --testPathPattern=public/tests",
    "test:usage": "jest --testPathPattern=src/tests/usage",
    "test:verbose": "jest --verbose",
    "start": "node src/server.js",
    "build:css": "tailwindcss -i ./public/styles/tailwind.css -o ./public/dist/styles.css --watch",
    "cache:bust": "node scripts/bust-cache.js",
    "sync:plans": "node scripts/cli-commands.js sync",
    "list:plans": "node scripts/cli-commands.js list",
    "webhook:plans": "node scripts/add-webhook-support.js",
    "test:stress": "node src/tests/stress/stress-test.js"
    },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jojo6550/jojo6550.github.io.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jojo6550/jojo6550.github.io/issues"
  },
  "homepage": "https://github.com/jojo6550/jojo6550.github.io#readme",
